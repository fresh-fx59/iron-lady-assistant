# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Comma-separated Telegram user IDs allowed to use the bot (empty = deny all)
ALLOWED_USER_IDS=

# Default Claude model (sonnet, opus, haiku)
DEFAULT_MODEL=sonnet

# Working directory for Claude Code subprocess
CLAUDE_WORKING_DIR=

# Max seconds to wait for Claude response
MAX_RESPONSE_TIMEOUT=300
