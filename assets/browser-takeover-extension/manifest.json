{
  "manifest_version": 3,
  "name": "ILA Browser Takeover",
  "version": "0.1.0",
  "description": "Attach a Chrome tab to iron-lady-assistant via a local relay.",
  "permissions": ["debugger", "tabs", "activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": {
    "default_title": "ILA Browser Takeover (click to attach/detach)"
  },
  "options_ui": { "page": "options.html", "open_in_tab": true }
}
