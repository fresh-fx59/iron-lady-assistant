# ─────────────────────────────────────────────────────────────
# Telegram Claude Code Bot — Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run the interactive setup instead:
#   bash setup.sh
# ─────────────────────────────────────────────────────────────

# REQUIRED — Your Telegram bot token
# Get one from @BotFather on Telegram: https://t.me/BotFather
# 1. Send /newbot to @BotFather
# 2. Pick a name and username for your bot
# 3. Copy the token (looks like: 123456:ABC-DEF1234ghIkl-zyx57W2v...)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# REQUIRED — Who can use the bot
# Comma-separated Telegram user IDs. Only these users get responses.
# Find your ID: send any message to @userinfobot on Telegram
# Example: 123456789 or 123456789,987654321 for multiple users
ALLOWED_USER_IDS=

# OPTIONAL — Allowed chats/channels where the bot can respond even without from_user ID
# Use numeric Telegram chat IDs (for channels it usually starts with -100...)
# Example: -1001234567890,-1009876543210
ALLOWED_CHAT_IDS=

# Default Claude model (you can switch anytime with /model in the bot)
#   sonnet — Fast and smart (recommended)
#   opus   — Most capable, slower
#   haiku  — Fastest, cheapest
DEFAULT_MODEL=sonnet

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Advanced settings (safe to leave as-is)
# ─────────────────────────────────────────────────────────────

# Directory Claude works in (leave empty for default)
CLAUDE_WORKING_DIR=

# Idle timeout - seconds without output before killing (default: 2 minutes)
IDLE_TIMEOUT=120

# Telegram HTTP timeout for each API request in seconds (default: 90)
TELEGRAM_REQUEST_TIMEOUT_SECONDS=90

# Telegram long-poll timeout for getUpdates in seconds (default: 30)
TELEGRAM_POLLING_TIMEOUT_SECONDS=30

# Polling reconnect backoff settings (defaults: min 1s, max 30s, factor 1.5, jitter 0.1)
TELEGRAM_BACKOFF_MIN_SECONDS=1.0
TELEGRAM_BACKOFF_MAX_SECONDS=30.0
TELEGRAM_BACKOFF_FACTOR=1.5
TELEGRAM_BACKOFF_JITTER=0.1

# Min seconds between progress message updates (default: 3 seconds)
PROGRESS_DEBOUNCE_SECONDS=3.0

# Port for Prometheus metrics (default: 9101, set to 0 to disable)
METRICS_PORT=9101

# F08 governance rollout mode:
#   shadow          -> monitor-only, no response-path enforcement
#   enforce_limited -> enforcement for risky self-mod operations only
#   enforce_scoped  -> scoped enforcement by policy classes
#   enforce_full    -> full policy mode (only after rollout sign-off)
F08_GOVERNANCE_MODE=shadow

# Logical scope label for F08 governance metrics (default: self_mod_only)
F08_ENFORCEMENT_SCOPE=self_mod_only

# Run recurring schedules inside the polling bot process.
# Set to 0 when using the standalone scheduler daemon.
EMBEDDED_SCHEDULER_ENABLED=1

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Telegram read proxy for channel/chat ingestion
# ─────────────────────────────────────────────────────────────

# Proxy listener (used by the proxy service itself)
TELEGRAM_PROXY_BIND_HOST=127.0.0.1
TELEGRAM_PROXY_BIND_PORT=8787

# Proxy base URL and bearer token (used by the bot/scheduler client side)
TELEGRAM_PROXY_BASE_URL=http://127.0.0.1:8787
TELEGRAM_PROXY_API_KEY=
TELEGRAM_PROXY_REQUEST_TIMEOUT_SECONDS=30

# Optional allowlists for the proxy. Leave channel ids empty to allow all broadcast
# channels visible to the Telegram user session. Leave chat ids empty to deny direct
# chat reads while still allowing linked discussion chats returned from allowlisted channels.
TELEGRAM_PROXY_ALLOWED_CHANNEL_IDS=
TELEGRAM_PROXY_ALLOWED_CHAT_IDS=

# systemd credential name used to load the Fernet decryption key into the proxy.
# Prefer LoadCredentialEncrypted= in the proxy service unit.
TELEGRAM_PROXY_KEY_CREDENTIAL_NAME=telegram_proxy_key

# Optional emergency fallback path for local testing without systemd credentials.
TELEGRAM_PROXY_KEY_FALLBACK_PATH=

# Encrypted JSON payload for the Telegram user account credentials.
# Generate with:
#   python3 -m src.telegram_proxy_crypto_tool generate-key
#   python3 -m src.telegram_proxy_crypto_tool encrypt --key <fernet_key> --api-id <id> --api-hash <hash> --session-string <telethon_string_session>
TELEGRAM_PROXY_ENCRYPTED_CREDENTIALS=

# Optional Telegram destination for scheduler lifecycle notifications.
# If set, the scheduler daemon mirrors only high-signal events there by default.
SCHEDULER_NOTIFY_CHAT_ID=
SCHEDULER_NOTIFY_THREAD_ID=
# Notification level: all | failures | off
SCHEDULER_NOTIFY_LEVEL=failures
