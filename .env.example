# ─────────────────────────────────────────────────────────────
# Telegram Claude Code Bot — Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run the interactive setup instead:
#   bash setup.sh
# ─────────────────────────────────────────────────────────────

# REQUIRED — Your Telegram bot token
# Get one from @BotFather on Telegram: https://t.me/BotFather
# 1. Send /newbot to @BotFather
# 2. Pick a name and username for your bot
# 3. Copy the token (looks like: 123456:ABC-DEF1234ghIkl-zyx57W2v...)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# REQUIRED — Who can use the bot
# Comma-separated Telegram user IDs. Only these users get responses.
# Find your ID: send any message to @userinfobot on Telegram
# Example: 123456789 or 123456789,987654321 for multiple users
ALLOWED_USER_IDS=

# Default Claude model (you can switch anytime with /model in the bot)
#   sonnet — Fast and smart (recommended)
#   opus   — Most capable, slower
#   haiku  — Fastest, cheapest
DEFAULT_MODEL=sonnet

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Advanced settings (safe to leave as-is)
# ─────────────────────────────────────────────────────────────

# Directory Claude works in (leave empty for default)
CLAUDE_WORKING_DIR=

# Max seconds to wait for a response (default: 5 minutes)
MAX_RESPONSE_TIMEOUT=300

# Port for Prometheus metrics (default: 9101, set to 0 to disable)
METRICS_PORT=9101
