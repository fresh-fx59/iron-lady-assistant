 async def callback_model(query: CallbackQuery) -> None:
     """Handle model selection via inline keyboard."""
     if not _is_authorized(query.from_user and query.from_user.id):
         return

     session = session_manager.get(query.message.chat.id)
     new_model = query.data.split(":", 1)[0].lower()

     if new_model not in VALID_MODELS:
         await query.answer(f"Invalid model: {new_model}")
         return

     if new_model == session.model:
         await query.answer("Already using this model.")
         return

     session_manager.set_model(query.message.chat.id, new_model)
     await query.answer(f"Model switched to {new_model}", parse_mode="HTML")

