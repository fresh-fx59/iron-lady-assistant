{
  "providers": [
    {
      "name": "codex",
      "description": "Codex CLI (apikey) via CLIProxyAPI :8317 -> linkapi (default gpt-5.4)",
      "cli": "codex",
      "model": "gpt-5.4",
      "models": [
        "gpt-5.4",
        "gpt-5.5",
        "gpt-5.4-pro",
        "gpt-5.5-pro",
        "gpt-5.3-codex",
        "gpt-5.2",
        "gpt-5",
        "gpt-5.4-mini",
        "gpt-5.4-nano"
      ],
      "env": {}
    },
    {
      "name": "claude",
      "description": "Anthropic Claude",
      "cli": "claude",
      "env": {}
    },
    {
      "name": "glm4.7",
      "description": "GLM-4.7 via Cloud.ru (LiteLLM :4000)",
      "cli": "claude",
      "env": {
        "ANTHROPIC_BASE_URL": "http://0.0.0.0:4000",
        "ANTHROPIC_AUTH_TOKEN": "any-placeholder-value",
        "ANTHROPIC_MODEL": "claude-3-5-sonnet-latest"
      }
    },
    {
      "name": "qwen3-coder",
      "description": "Qwen3-Coder-480B via DeepInfra (LiteLLM :4001)",
      "cli": "claude",
      "env": {
        "ANTHROPIC_BASE_URL": "http://0.0.0.0:4001",
        "ANTHROPIC_AUTH_TOKEN": "any-placeholder-value",
        "ANTHROPIC_MODEL": "claude-3-5-sonnet-latest"
      }
    },
    {
      "name": "glm4.7-flash-lm-studio",
      "description": "GLM-4.7 Flash MLX (LM Studio :4002)",
      "cli": "claude",
      "env": {
        "ANTHROPIC_BASE_URL": "http://0.0.0.0:4002",
        "ANTHROPIC_AUTH_TOKEN": "any-placeholder-value",
        "ANTHROPIC_MODEL": "claude-3-5-sonnet-latest"
      }
    }
  ],
  "rate_limit_patterns": [
    "rate limit",
    "rate_limit",
    "overloaded",
    "over capacity",
    "429",
    "too many requests",
    "token limit",
    "billing",
    "quota exceeded",
    "usage cap",
    "usage limit",
    "you've hit your usage limit",
    "credit",
    "exceeded your"
  ],
  "cooldown_minutes": 30
}
